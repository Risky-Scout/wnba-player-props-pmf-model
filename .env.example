# WNBA Player Props PMF Model — Environment Template
# Copy to .env and fill in your values (never commit .env to git).

# BDL API Key (GOAT tier required for advanced stats, odds, player props, shot locations)
# Get yours at https://www.balldontlie.io/
BDL_API_KEY=your_goat_tier_api_key_here

# Season year (e.g. 2026 for the current WNBA season)
SEASON=2026

# Optional: override default output directories
# DELIVERIES_DIR=deliveries/today
# ARTIFACTS_DIR=artifacts
