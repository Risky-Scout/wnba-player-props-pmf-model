  "selection_rules": {
    "unit_of_split": "game_date",
    "outer_test": "strictly_forward_and_never_used_for_selection",
    "inner_selection": "prequential",
    "primary_market_metrics": [
      "log_loss_delta",
      "brier_delta"
    ],
    "required_secondary_metric": "auc_delta",
    "multiplicity": "Holm correction across props within each metric",
    "pushes": "exclude_from_binary_line_metrics_but_retain_for_full_pmf_scores",
    "minimum_recommended_settled_rows_per_prop": 300,
    "strict_pass": [
      "upper_95pct_cluster_bootstrap_CI(log_loss_model_minus_market) < 0",
      "upper_95pct_cluster_bootstrap_CI(brier_model_minus_market) < 0",
      "lower_95pct_cluster_bootstrap_CI(auc_model_minus_market) > 0",
      "Holm_adjusted_one_sided_p <= 0.05_for_all_three"
    ]
  }
}
